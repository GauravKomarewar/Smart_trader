# Smart Trader — Backend Environment Variables
# Copy this to .env and fill in your credentials

# ── Server ──────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://129.154.41.30:5173

# ── Shoonya Credentials ─────────────────────────────
SHOONYA_USER_ID=YOUR_USER_ID
SHOONYA_PASSWORD=YOUR_PASSWORD
SHOONYA_TOTP_KEY=YOUR_BASE32_TOTP_KEY
SHOONYA_VENDOR_CODE=YOUR_VENDOR_CODE
SHOONYA_OAUTH_SECRET=YOUR_OAUTH_SECRET
SHOONYA_HOST=https://trade.shoonya.com/NorenWClientAPI
SHOONYA_WEBSOCKET=wss://trade.shoonya.com/NorenWSTP

# ── Logging ─────────────────────────────────────────
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── JWT secret (for session tokens between frontend <-> backend) ─────────────
JWT_SECRET=changeme_use_a_long_random_string_here
JWT_EXPIRE_HOURS=24
